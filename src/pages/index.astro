---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const allPosts = await getCollection("blog");
const gesorteerd = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const uitgelicht = gesorteerd.find((post) => post.data.featured) ?? null;
const blogroll = gesorteerd.filter((post) => post !== uitgelicht);

const datumFormatter = new Intl.DateTimeFormat("nl-NL", { dateStyle: "long" });
---

<Layout>
  <main class="mx-auto max-w-3xl px-4 py-8">
    {
      uitgelicht && (
        <section class="mb-12 rounded-lg border border-gray-200 p-6">
          <p class="mb-3 text-xs font-semibold tracking-widest text-gray-500 uppercase">
            Uitgelicht
          </p>
          <a
            href={`/blog/${uitgelicht.id}`}
            class="group text-inherit no-underline"
          >
            <h2 class="mb-1 text-xl group-hover:underline">
              {uitgelicht.data.title}
            </h2>
          </a>
          <p class="mb-2 flex flex-wrap items-center gap-3 text-sm text-gray-500">
            <time datetime={uitgelicht.data.pubDate.toISOString()}>
              {datumFormatter.format(uitgelicht.data.pubDate)}
            </time>
            {uitgelicht.data.tags && (
              <span class="flex flex-wrap gap-1.5">
                {uitgelicht.data.tags.map((tag) => (
                  <span class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs">
                    {tag}
                  </span>
                ))}
              </span>
            )}
          </p>
          <p class="leading-relaxed text-gray-700">
            {uitgelicht.data.description}
          </p>
        </section>
      )
    }

    <h1 class="mb-8 text-3xl">Blog</h1>

    <ul class="flex list-none flex-col gap-8 p-0">
      {
        blogroll.map((post) => (
          <li class="border-b border-gray-200 pb-8 last:border-b-0">
            <a
              href={`/blog/${post.id}`}
              class="group text-inherit no-underline"
            >
              <h2 class="mb-1 text-xl group-hover:underline">
                {post.data.title}
              </h2>
            </a>
            <p class="mb-2 flex flex-wrap items-center gap-3 text-sm text-gray-500">
              <time datetime={post.data.pubDate.toISOString()}>
                {datumFormatter.format(post.data.pubDate)}
              </time>
              {post.data.tags && (
                <span class="flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag) => (
                    <span class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs">
                      {tag}
                    </span>
                  ))}
                </span>
              )}
            </p>
            <p class="leading-relaxed text-gray-700">{post.data.description}</p>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
