---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BlogPostItem from "../components/BlogPostItem.astro";
import LinkItem from "../components/LinkItem.astro";
import SnippetItem from "../components/SnippetItem.astro";

const allPosts = await getCollection("blog");
const allLinks = await getCollection("links");
const allSnippets = await getCollection("snippets");

type FeedEntry =
  | CollectionEntry<"blog">
  | CollectionEntry<"links">
  | CollectionEntry<"snippets">;

const feed: FeedEntry[] = [...allPosts, ...allLinks, ...allSnippets].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const uitgelicht = feed.find((entry) => entry.data.featured) ?? null;
const feedZonderUitgelicht = feed.filter((entry) => entry !== uitgelicht);

const datumFormatter = new Intl.DateTimeFormat("nl-NL", {
  weekday: "short",
  day: "numeric",
  month: "short",
  year: "numeric",
});
---

<Layout>
  <main class="mx-auto max-w-3xl px-4 py-8">
    {
      uitgelicht && uitgelicht.data.type === "blog" && (
        <section class="mb-12 rounded-lg border border-gray-200 p-6">
          <p class="mb-3 text-xs font-semibold tracking-widest text-gray-500 uppercase">
            Uitgelicht
          </p>
          <a
            href={`/blog/${uitgelicht.id}`}
            class="group text-inherit no-underline"
          >
            <h2 class="mb-1 text-xl group-hover:underline">
              {uitgelicht.data.title}
            </h2>
          </a>
          <p class="mb-2 flex flex-wrap items-center gap-3 text-sm text-gray-500">
            <time datetime={uitgelicht.data.pubDate.toISOString()}>
              {datumFormatter.format(uitgelicht.data.pubDate)}
            </time>
            {uitgelicht.data.tags && (
              <span class="flex flex-wrap gap-1.5">
                {uitgelicht.data.tags.map((tag) => (
                  <span class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs">
                    {tag}
                  </span>
                ))}
              </span>
            )}
          </p>
          <p class="leading-relaxed text-gray-700">
            {uitgelicht.data.description}
          </p>
        </section>
      )
    }

    <section>
      <h2 class="mb-8 font-sans text-2xl">Feed</h2>
      <div id="feed" class="flex flex-col gap-y-8 p-0">
        {
          feedZonderUitgelicht.map((entry) => {
            switch (entry.collection) {
              case "blog":
                return <BlogPostItem post={entry} />;
              case "links":
                return <LinkItem link={entry} />;
              case "snippets":
                return <SnippetItem snippet={entry} />;
              default:
                break;
            }
          })
        }
      </div>
    </section>
  </main>
</Layout>
