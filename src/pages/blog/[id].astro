---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const datumFormatter = new Intl.DateTimeFormat("nl-NL", { dateStyle: "long" });
---

<Layout title={post.data.title}>
  <main>
    <a class="terug" href="/blog">← Terug naar overzicht</a>
    <article>
      <header>
        <h1 class="font-pixel">{post.data.title}</h1>
        <p class="meta">
          <span>Door {post.data.author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {datumFormatter.format(post.data.pubDate)}
          </time>
        </p>
        {
          post.data.tags && (
            <p class="mt-0 mb-8 flex flex-wrap gap-1.5">
              {post.data.tags.map((tag) => (
                <span class="rounded bg-gray-100 px-2 py-0.5 font-mono text-xs font-normal tracking-wide text-gray-700">
                  {tag}
                </span>
              ))}
            </p>
          )
        }
      </header>
      <div class="content">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1rem;
    font-family: system-ui, sans-serif;
  }

  .terug {
    display: inline-block;
    margin-bottom: 2rem;
    color: #6b7280;
    text-decoration: none;
    font-size: 0.875rem;
  }

  .terug:hover {
    color: #111827;
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
    line-height: 1.25;
  }

  .meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    color: #6b7280;
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin: 0 0 2rem;
  }

  .tag {
    background: #f3f4f6;
    border-radius: 0.25rem;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    color: #374151;
  }

  .content {
    line-height: 1.75;
    color: #1f2937;
  }

  .content :global(h2) {
    font-size: 1.375rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .content :global(h3) {
    font-size: 1.125rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .content :global(pre) {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    margin: 1.25rem 0;
  }

  .content :global(code):not(:global(pre code)) {
    background: #f1f5f9;
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.875em;
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 1.25rem 0;
  }

  .content :global(th),
  .content :global(td) {
    border: 1px solid #e5e7eb;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .content :global(th) {
    background: #f9fafb;
    font-weight: 600;
  }

  .content :global(a) {
    color: #2563eb;
  }
</style>
