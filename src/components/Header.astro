---

---

<header
  class="sticky top-0 z-10 flex h-16 items-center justify-between border-b border-gray-100 bg-white px-6"
>
  <a href="/" class="font-sans text-xl font-bold tracking-tight text-gray-900"
    >JT</a
  >

  <nav class="hidden items-center gap-8 text-sm text-gray-600 md:flex">
    <a href="/projecten" class="transition-colors hover:text-gray-900"
      >Projecten</a
    >
    <a href="/contact" class="transition-colors hover:text-gray-900">Contact</a>
  </nav>

  <button
    popovertarget="nav-drawer"
    class="hamburger-btn -mr-2 flex h-10 w-10 items-center justify-center rounded-lg text-gray-700 transition-colors hover:bg-gray-100 md:hidden"
    aria-label="Menu openen"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="4" y1="6" x2="20" y2="6"></line>
      <line x1="4" y1="12" x2="20" y2="12"></line>
      <line x1="4" y1="18" x2="20" y2="18"></line>
    </svg>
  </button>
</header>

<div id="nav-drawer" popover="auto" aria-label="Navigatie">
  <div class="flex justify-end p-4 pb-2">
    <button
      popovertarget="nav-drawer"
      popovertargetaction="hide"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-700 transition-colors hover:bg-gray-100"
      aria-label="Menu sluiten"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <nav class="flex flex-col gap-1 px-4">
    <a
      href="/projecten"
      class="rounded-lg px-4 py-3 text-gray-700 transition-colors hover:bg-gray-50 hover:text-gray-900"
      >Projecten</a
    >
    <a
      href="/contact"
      class="rounded-lg px-4 py-3 text-gray-700 transition-colors hover:bg-gray-50 hover:text-gray-900"
      >Contact</a
    >
  </nav>
</div>

<style>
  .hamburger-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  #nav-drawer {
    /* Override popover UA defaults */
    position: fixed;
    inset: 0 0 0 auto;
    margin: 0;
    padding: 0;
    border: none;
    width: min(320px, 85vw);
    height: 100dvh;
    background: white;
    box-shadow: -4px 0 32px rgb(0 0 0 / 0.1);

    /* Closed (base) state — where the exit transition ends */
    transform: translateX(100%);
    opacity: 0;

    transition-property: transform, opacity, overlay, display;
    transition-duration: 0.3s;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-behavior: allow-discrete;
  }

  #nav-drawer:popover-open {
    transform: translateX(0);
    opacity: 1;
  }

  /* Where the enter transition starts */
  @starting-style {
    #nav-drawer:popover-open {
      transform: translateX(100%);
      opacity: 0;
    }
  }

  #nav-drawer::backdrop {
    background: rgb(0 0 0 / 0%);
    backdrop-filter: blur(0px);

    transition-property: display, overlay, background-color, backdrop-filter;
    transition-duration: 0.3s;
    transition-timing-function: ease;
    transition-behavior: allow-discrete;
  }

  #nav-drawer:popover-open::backdrop {
    background: rgb(0 0 0 / 25%);
    backdrop-filter: blur(2px);
  }

  @starting-style {
    #nav-drawer:popover-open::backdrop {
      background: rgb(0 0 0 / 0%);
      backdrop-filter: blur(0px);
    }
  }
</style>
